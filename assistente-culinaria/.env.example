# Groq — console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# LangSmith — smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=assistente-culinaria

# Discord — dois canais, dois webhooks (canal → Integrações → Webhooks → Criar Webhook)
DISCORD_WEBHOOK_URGENTE=https://discord.com/api/webhooks/SEU_ID/TOKEN_ALERTAS
DISCORD_WEBHOOK_NORMAL=https://discord.com/api/webhooks/SEU_ID/TOKEN_NORMAIS

# Telegram — @BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
